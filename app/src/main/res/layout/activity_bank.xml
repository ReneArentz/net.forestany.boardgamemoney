<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/bank_main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:fitsSystemWindows="true"
    tools:ignore="HardcodedText">

    <!-- Top player section -->
    <RelativeLayout
        android:id="@+id/playerSection"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:padding="16dp"
        android:background="@color/colorSecondary">

        <!-- Left Arrow -->
        <ImageButton
            android:id="@+id/arrowLeft"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_alignParentStart="true"
            android:layout_centerVertical="true"
            android:contentDescription="Top Player Section Arrow Left"
            android:src="@android:drawable/ic_media_previous"
            android:background="@android:color/transparent" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="8dp"
            android:gravity="center_horizontal">

            <!-- Player Icon -->
            <ImageView
                android:id="@+id/playerIcon"
                android:layout_width="52dp"
                android:layout_height="52dp"
                android:contentDescription="Top Player Section Icon"
                android:src="@android:drawable/ic_menu_myplaces"
                app:tint="#000000"
                android:layout_marginEnd="12dp"/>

            <!-- Player Info Column -->
            <LinearLayout
                android:id="@+id/playerInfoColumn"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center_horizontal">

                <!-- Player Name -->
                <TextView
                    android:id="@+id/playerName"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Player Name"
                    android:textColor="@color/colorOnSecondary"
                    android:textSize="22sp"
                    android:textStyle="bold"
                    android:ellipsize="end"
                    android:singleLine="true" />

                <!-- Player Money -->
                <TextView
                    android:id="@+id/playerMoney"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="0 €"
                    android:textColor="@color/colorOnSecondary"
                    android:textSize="20sp"
                    android:textStyle="bold" />
            </LinearLayout>
        </LinearLayout>

        <!-- Right Arrow -->
        <ImageButton
            android:id="@+id/arrowRight"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:contentDescription="Top Player Section Arrow Right"
            android:src="@android:drawable/ic_media_next"
            android:background="@android:color/transparent" />
    </RelativeLayout>

    <!-- Banknotes & Controls -->
    <LinearLayout
        android:id="@+id/banknoteSection"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="5"
        android:orientation="vertical"
        android:padding="12dp">

        <!-- Banknote Grid -->
        <GridLayout
            android:id="@+id/banknoteGrid"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:columnCount="2"
            android:rowCount="4"
            android:alignmentMode="alignMargins"
            android:useDefaultMargins="true"
            android:layout_margin="4dp">

            <!-- Note 1 -->
            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:layout_margin="6dp">

                <ImageView
                    android:id="@+id/note1"
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    android:adjustViewBounds="true"
                    android:scaleType="fitXY"
                    android:contentDescription="1"
                    android:src="@android:drawable/btn_star_big_on"
                    app:layout_constraintDimensionRatio="2:0.8"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"/>
            </androidx.constraintlayout.widget.ConstraintLayout>

            <!-- Note 5 -->
            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:layout_margin="6dp">

                <ImageView
                    android:id="@+id/note5"
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    android:adjustViewBounds="true"
                    android:scaleType="fitXY"
                    android:contentDescription="5"
                    android:src="@android:drawable/btn_star_big_on"
                    app:layout_constraintDimensionRatio="2:0.8"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"/>
            </androidx.constraintlayout.widget.ConstraintLayout>

            <!-- Note 10 -->
            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:layout_margin="6dp">

                <ImageView
                    android:id="@+id/note10"
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    android:adjustViewBounds="true"
                    android:scaleType="fitXY"
                    android:contentDescription="10"
                    android:src="@android:drawable/btn_star_big_on"
                    app:layout_constraintDimensionRatio="2:0.8"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"/>
            </androidx.constraintlayout.widget.ConstraintLayout>

            <!-- Note 20 -->
            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:layout_margin="6dp">

                <ImageView
                    android:id="@+id/note20"
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    android:adjustViewBounds="true"
                    android:scaleType="fitXY"
                    android:contentDescription="20"
                    android:src="@android:drawable/btn_star_big_on"
                    app:layout_constraintDimensionRatio="2:0.8"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"/>
            </androidx.constraintlayout.widget.ConstraintLayout>

            <!-- Note 50 -->
            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:layout_margin="6dp">

                <ImageView
                    android:id="@+id/note50"
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    android:adjustViewBounds="true"
                    android:scaleType="fitXY"
                    android:contentDescription="50"
                    android:src="@android:drawable/btn_star_big_on"
                    app:layout_constraintDimensionRatio="2:0.8"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"/>
            </androidx.constraintlayout.widget.ConstraintLayout>

            <!-- Note 100 -->
            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:layout_margin="6dp">

                <ImageView
                    android:id="@+id/note100"
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    android:adjustViewBounds="true"
                    android:scaleType="fitXY"
                    android:contentDescription="100"
                    android:src="@android:drawable/btn_star_big_on"
                    app:layout_constraintDimensionRatio="2:0.8"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"/>
            </androidx.constraintlayout.widget.ConstraintLayout>

            <!-- Note 500 -->
            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:layout_margin="6dp">

                <ImageView
                    android:id="@+id/note500"
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    android:adjustViewBounds="true"
                    android:scaleType="fitXY"
                    android:contentDescription="500"
                    android:src="@android:drawable/btn_star_big_on"
                    app:layout_constraintDimensionRatio="2:0.8"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"/>
            </androidx.constraintlayout.widget.ConstraintLayout>

            <!-- Note 1000 -->
            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_columnWeight="1"
                android:layout_margin="6dp">

                <ImageView
                    android:id="@+id/note1000"
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    android:adjustViewBounds="true"
                    android:scaleType="fitXY"
                    android:contentDescription="1000"
                    android:src="@android:drawable/btn_star_big_on"
                    app:layout_constraintDimensionRatio="2:0.8"
                    app:layout_constraintTop_toTopOf="parent"
                    app:layout_constraintBottom_toBottomOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintEnd_toEndOf="parent"/>
            </androidx.constraintlayout.widget.ConstraintLayout>

        </GridLayout>

        <!-- Transfer Amount -->
        <EditText
            android:id="@+id/transferAmount"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:importantForAutofill="no"
            android:inputType="none"
            android:focusable="false"
            android:text="0 €"
            android:gravity="center"
            android:textSize="20sp"
            android:layout_marginTop="6dp"
            tools:ignore="LabelFor" />

        <!-- Buttons -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginTop="6dp">

            <Button
                android:id="@+id/btnOk"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Transfer"
                tools:ignore="ButtonStyle" />

            <Button
                android:id="@+id/btnCancel"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/text_cancel"
                android:layout_marginStart="16dp"
                tools:ignore="ButtonStyle" />

        </LinearLayout>

        <!-- Bottom Player Selector -->
        <RelativeLayout
            android:id="@+id/bottomPlayerSection"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:padding="8dp"
            android:background="@color/colorSecondary">

            <!-- Left Arrow -->
            <ImageButton
                android:id="@+id/bottomArrowLeft"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_alignParentStart="true"
                android:contentDescription="Bottom Player Section Arrow Left"
                android:src="@android:drawable/ic_media_previous"
                android:background="@android:color/transparent" />

            <!-- Player Name -->
            <TextView
                android:id="@+id/bottomPlayerName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerHorizontal="true"
                android:text="Bank"
                android:textColor="@android:color/black"
                android:textSize="20sp"
                android:textStyle="bold" />

            <!-- Player Balance -->
            <TextView
                android:id="@+id/bottomPlayerBalance"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_below="@id/bottomPlayerName"
                android:layout_centerHorizontal="true"
                android:text="∞"
                android:textColor="@android:color/black"
                android:textSize="18sp"
                android:textStyle="italic" />

            <!-- Right Arrow -->
            <ImageButton
                android:id="@+id/bottomArrowRight"
                android:layout_width="48dp"
                android:layout_height="48dp"
                android:layout_alignParentEnd="true"
                android:contentDescription="Bottom Player Section Arrow Right"
                android:src="@android:drawable/ic_media_next"
                android:background="@android:color/transparent" />

        </RelativeLayout>

        <TextView
            android:id="@+id/ping"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_vertical|top|end"
            android:text="99 ms"
            android:textSize="8sp"
            android:textColor="@color/colorOnBackground" />

    </LinearLayout>

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/toolbar_bank"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:layout_marginBottom="0dp"
        android:elevation="4dp"
        android:minHeight="?attr/actionBarSize"
        app:theme="@style/BoardGameMoneyToolbar"
        app:layout_constraintBottom_toBottomOf="@+id/banknoteSection"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />
</LinearLayout>